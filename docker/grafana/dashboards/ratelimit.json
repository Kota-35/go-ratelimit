{
  "title": "Rate Limit Algorithm Dashboard",
  "uid": "ratelimit-algo",
  "schemaVersion": 39,
  "refresh": "5s",
  "time": { "from": "now-5m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "リクエスト数（許可 / 拒否）per second",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(ratelimit_requests_total[30s])",
          "legendFormat": "{{instance}} {{algorithm}} {{result}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "拒否率 (denied / total)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(ratelimit_requests_total{result=\"denied\"}[30s]) / rate(ratelimit_requests_total[30s])",
          "legendFormat": "{{instance}} {{algorithm}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "残許可数（Remaining）",
      "description": "0 に近いほどレート制限の上限に近い。アルゴリズムごとの消費パターンの違いが出る。",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "ratelimit_remaining",
          "legendFormat": "{{instance}} {{algorithm}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "累計リクエスト数",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(ratelimit_requests_total)",
          "legendFormat": "total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "累計拒否数",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(ratelimit_requests_total{result=\"denied\"})",
          "legendFormat": "denied",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "red" } }
      }
    }
  ]
}
